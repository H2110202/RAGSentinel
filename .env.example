# RAGFlow Connection (Required)
RAGFLOW_URL=http://your-ragflow-server:9380
RAGFLOW_API_KEY=ragflow-your-api-key-here
RAGFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5@BAAI
RAGFLOW_CHUNK_METHOD=naive
RAGFLOW_LLM_MODEL=deepseek-chat@DeepSeek

# DingTalk Integration (Optional)
DINGTALK_APPID=your-dingtalk-appid
DINGTALK_APPSECRET=your-dingtalk-appsecret

# Security (Required - change in production!)
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///./data/permission_admin.db

# Server
HOST=0.0.0.0
PORT=8088
LOG_LEVEL=INFO

# Token expiration (minutes, default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Docker Compose ports (optional overrides)
# BACKEND_PORT=8088
# FRONTEND_PORT=3000
